{
  "name": "valr-perpetual-grid-bot",
  "version": "4.0.0",
  "description": "Production-grade perpetual futures grid trading bot for VALR exchange",
  "type": "module",
  "main": "dist/app/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app/main.js",
    "dry-run": "node dist/scripts/dry-run.js configs/sol.example.json",
    "status": "node dist/scripts/status.js",
    "reset": "node dist/scripts/reset-state.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "valr",
    "grid-trading",
    "perpetual-futures",
    "crypto-bot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/decimal.js": "^0.0.32",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/ws": "^8.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.9.3"
  }
}
